# ローカル開発（npm run dev）で Vite が自動読み込みします。
#
# ■ コンシェルジュ（npm run dev のみ）: .env に GEMINI_API_KEY=（VITE_ 不要）→ Vite が Node から Gemini を呼ぶ
#
# ■ サーバー経由のみ: GEMINI_API_KEY + 下記 localhost:3000 → npm run dev:full
VITE_API_BASE_URL=http://localhost:3000
#
# ■ 既に Vercel にデプロイ済みで、ローカルから Vercel の API だけ使う場合
#   VITE_API_BASE_URL=https://あなたのプロジェクト.vercel.app
#
# Vercel Protection でリモート直叩きが 401 になるとき: .env.local に VERCEL_PROTECTION_BYPASS=...（gitignore）
