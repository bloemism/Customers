# ローカルで Vercel の API を使う（推奨・GEMINI は Vercel のみにキー設定で可）
# → リポジトリ同梱の .env.development を編集（VITE_API_BASE_URL）

# Supabase設定
VITE_SUPABASE_URL=your_supabase_project_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Google Maps Static API設定
VITE_GOOGLE_MAPS_API_KEY=your_google_maps_static_api_key

# Stripe設定（将来的に使用）
VITE_STRIPE_PUBLISHABLE_KEY=your_stripe_publishable_key

# アプリケーション設定
VITE_APP_NAME=87app
VITE_APP_VERSION=1.0.0

# Google AI（Gemini）
#
# ■ ローカルで npm run dev のみ（推奨）: .env に GEMINI_API_KEY（VITE_ 不要）。Vite が Node から呼び出し、キーはフロントに出ません。
# 任意: GEMINI_MODEL=gemini-2.5-flash（未指定時も同じ。旧 1.5 系は API で未提供のことがあります）
#
# ■ キーを Vite に置かず API サーバーだけで使う: npm run dev:full（.env は server-local / デプロイ先の GEMINI_API_KEY）
#
# ■ 本番: Vercel 等のサーバーに GEMINI_API_KEY（または GOOGLE_AI_API_KEY）
GEMINI_API_KEY=your_google_ai_studio_api_key
# 任意: 未指定時は gemini-2.5-flash
# GEMINI_MODEL=gemini-2.5-pro
